SERVICE_NAME=user-service
SERVICE_ENV=development
SERVICE_PORT=8002
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
TRUSTED_PROXY_IPS=

DATABASE_URL=postgresql+asyncpg://user_service:change_me_user_db_password@postgres-user:5432/user_service
REDIS_URL=redis://:change_me_redis_password@redis:6379/1

JWT_ALGORITHM=RS256
JWT_ISSUER=backend-platform
JWT_AUDIENCE=backend-clients
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_SECURE_KEY\n-----END PUBLIC KEY-----"
PRIVACY_KEY_PEPPER=change_me_with_long_random_secret

RATE_LIMIT_PROFILE_WRITE_PER_MINUTE=30
RATE_LIMIT_ROLES_WRITE_PER_MINUTE=10
