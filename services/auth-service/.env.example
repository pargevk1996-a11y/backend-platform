# DO NOT overwrite services/auth-service/.env on AWS with this file wholesale.
# EC2/production: run infra/scripts/render_prod_env_from_secrets.py (see docs/smtp-aws-ec2.md),
# then edit only SMTP_* lines / paste App Password. Local dev: use bootstrap + generate_dev_env or
# copy this file once and fill JWT/TOTP/DB secrets — invalid RSA/TOTP/Fernet will crash auth-service.
#
SERVICE_NAME=auth-service
SERVICE_ENV=development
SERVICE_PORT=8001
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
TRUSTED_PROXY_IPS=

DATABASE_URL=postgresql+asyncpg://auth_service:change_me_auth_db_password@postgres-auth:5432/auth_service
REDIS_URL=redis://:change_me_redis_password@redis:6379/0

JWT_ALGORITHM=RS256
JWT_ISSUER=backend-platform
JWT_AUDIENCE=backend-clients
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_SECURE_KEY\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_SECURE_KEY\n-----END PUBLIC KEY-----"

REFRESH_TOKEN_HASH_PEPPER=change_me_with_long_random_secret
PRIVACY_KEY_PEPPER=change_me_with_another_long_random_secret
PASSWORD_RESET_TOKEN_PEPPER=change_me_with_password_reset_secret

TOTP_ISSUER=Backend Platform
TOTP_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY
TOTP_CODE_DIGITS=6
TOTP_INTERVAL_SECONDS=30

LOGIN_CHALLENGE_TTL_SECONDS=300
PASSWORD_RESET_TOKEN_TTL_SECONDS=900
#
# --- SMTP (Gmail): copy these into services/auth-service/.env ---
# The ONLY place for the real App Password is the next line (replace placeholder locally; do not commit).
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=pargevk1996@gmail.com
SMTP_PASSWORD=ycwb xpdh lfdn yfcv
SMTP_FROM_EMAIL=pargevk1996@gmail.com
SMTP_FROM_NAME=Backend-platform
SMTP_USE_TLS=true
SMTP_REQUIRE_DELIVERY=true

RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_2FA_PER_MINUTE=10
RATE_LIMIT_REFRESH_PER_MINUTE=30
RATE_LIMIT_REGISTER_PER_MINUTE=5
RATE_LIMIT_PASSWORD_RESET_PER_MINUTE=5

# Lock account after this many wrong passwords (same as LOGIN_MAX_FAILED_ATTEMPTS).
BRUTE_FORCE_LOGIN_MAX_ATTEMPTS=3
LOGIN_MAX_FAILED_ATTEMPTS=3
BRUTE_FORCE_LOGIN_WINDOW_SECONDS=300
BRUTE_FORCE_LOGIN_LOCK_SECONDS=900
BRUTE_FORCE_2FA_MAX_ATTEMPTS=5
BRUTE_FORCE_2FA_WINDOW_SECONDS=300
BRUTE_FORCE_2FA_LOCK_SECONDS=900
# Lock self-service reset after this many wrong codes (same as RESET_CODE_MAX_FAILED_ATTEMPTS).
BRUTE_FORCE_PASSWORD_RESET_MAX_ATTEMPTS=3
RESET_CODE_MAX_FAILED_ATTEMPTS=3
BRUTE_FORCE_PASSWORD_RESET_WINDOW_SECONDS=300
BRUTE_FORCE_PASSWORD_RESET_LOCK_SECONDS=900

# Shown in locked-account / blocked-reset API messages (not a secret).
SUPPORT_EMAIL=support@example.com

ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4
ARGON2_HASH_LENGTH=32
ARGON2_SALT_LENGTH=16
