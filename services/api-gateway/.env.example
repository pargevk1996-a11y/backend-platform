SERVICE_NAME=api-gateway
SERVICE_ENV=development
SERVICE_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

REDIS_URL=redis://:change_me_redis_password@redis:6379/2
AUTH_SERVICE_URL=http://auth-service:8001
USER_SERVICE_URL=http://user-service:8002
NOTIFICATION_SERVICE_URL=

JWT_ALGORITHM=RS256
JWT_ISSUER=backend-platform
JWT_AUDIENCE=backend-clients
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_SECURE_KEY\n-----END PUBLIC KEY-----"
PRIVACY_KEY_PEPPER=change_me_with_long_random_secret

UPSTREAM_TIMEOUT_SECONDS=10
# Docker bridge networks live in 172.16.0.0/12. Localhost for bare-metal dev.
TRUSTED_PROXY_IPS=172.16.0.0/12,127.0.0.1,::1
RATE_LIMIT_PUBLIC_AUTH_PER_MINUTE=30
RATE_LIMIT_PROTECTED_PER_MINUTE=120
RATE_LIMIT_GLOBAL_PER_MINUTE=300

AUTH_ACCESS_COOKIE_NAME=bp_access_token
AUTH_REFRESH_COOKIE_NAME=bp_refresh_token
AUTH_CSRF_COOKIE_NAME=bp_csrf_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_ACCESS_COOKIE_MAX_AGE_SECONDS=900
AUTH_REFRESH_COOKIE_MAX_AGE_SECONDS=2592000
