COMPOSE_PROJECT_NAME=backend-platform

# Public entrypoint (nginx)
PUBLIC_HTTP_PORT=80
SERVER_NAME=_
CLIENT_MAX_BODY_SIZE=2m
PROXY_READ_TIMEOUT=30s

# Edge security
TRUSTED_PROXY_IPS=172.16.0.0/12
CORS_ALLOWED_ORIGINS=https://api.example.com

# Runtime tuning
AUTH_SERVICE_WORKERS=2
USER_SERVICE_WORKERS=2
APP_WORKERS=4
UPSTREAM_TIMEOUT_SECONDS=10

# Rate limiting (requests per minute per client IP)
RATE_LIMIT_PUBLIC_AUTH_PER_MINUTE=30
RATE_LIMIT_PROTECTED_PER_MINUTE=120
RATE_LIMIT_GLOBAL_PER_MINUTE=300

# Data-store credentials. These are injected into DATABASE_URL / REDIS_URL
# strings. The *actual* Postgres and Redis servers read their passwords from
# /run/secrets/* (see infra/compose/docker-compose.prod.yml). Keep the values
# in sync with secrets/auth_db_password.txt etc.
AUTH_DB_PASSWORD=change_me_auth_db_password
USER_DB_PASSWORD=change_me_user_db_password
REDIS_PASSWORD=change_me_redis_password

# JWT and session tuning
JWT_ALGORITHM=RS256
JWT_ISSUER=backend-platform
JWT_AUDIENCE=backend-clients
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# 2FA
TOTP_ISSUER=Backend Platform
TOTP_CODE_DIGITS=6
TOTP_INTERVAL_SECONDS=30

# Browser cookie policy
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

# Optional downstream
NOTIFICATION_SERVICE_URL=

# SMTP is required when SERVICE_ENV=production for auth-service
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_REQUIRE_DELIVERY=true
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=

#
# SECRETS ARE LOADED FROM FILES, NOT FROM THIS FILE.
#
# Create the following files before the first `docker compose up` and chmod 600
# them. They are mounted read-only into containers via Docker secrets and
# picked up by <FIELD>_FILE env vars declared in docker-compose.prod.yml.
#
#   secrets/jwt_private.pem            # RSA 4096 private key (PKCS8, PEM)
#   secrets/jwt_public.pem             # RSA 4096 public  key (SPKI,  PEM)
#   secrets/totp_fernet.key            # Fernet.generate_key()
#   secrets/refresh_token_pepper.txt   # 48+ bytes of urandom, base64
#   secrets/privacy_key_pepper.txt     # 48+ bytes of urandom, base64
#   secrets/password_reset_pepper.txt  # 48+ bytes of urandom, base64
#   secrets/smtp_password.txt          # SMTP relay password (e.g. SES app pw)
#   secrets/auth_db_password.txt       # must match AUTH_DB_PASSWORD above
#   secrets/user_db_password.txt       # must match USER_DB_PASSWORD above
#   secrets/redis_password.txt         # must match REDIS_PASSWORD above
#
# See docs/deployment/aws-ec2.md for a turnkey provisioning script.
#
