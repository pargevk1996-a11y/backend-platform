COMPOSE_PROJECT_NAME=backend-platform
AUTH_DB_PASSWORD=change_me_auth_db_password
USER_DB_PASSWORD=change_me_user_db_password
REDIS_PASSWORD=change_me_redis_password
GATEWAY_PORT=8080

# Outbound email for auth-service (password reset).
# Canonical Gmail app password file: secrets/smtp_app_password.txt (legacy: secrets/smtp_password.txt).
# Optional: secrets/smtp_identity_email.txt (one line) fills SMTP_USERNAME/SMTP_FROM_EMAIL if unset.
# See docs/smtp-aws-ec2.md. Ad-hoc SMTP_PASSWORD= below only for bring-up (do not commit real values).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your@gmail.com
SMTP_FROM_EMAIL=your@gmail.com
SMTP_FROM_NAME=Backend Platform
SMTP_REQUIRE_DELIVERY=true
# SMTP_PASSWORD=
# Set false in production only after render fills SMTP + secrets; default true avoids auth-service crash on boot.
AUTH_ALLOW_MISSING_SMTP=true
# Shown in API messages when login or password reset is blocked (set in production secrets/env).
# SUPPORT_EMAIL=support@example.com
